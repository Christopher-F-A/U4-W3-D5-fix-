<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.1">
    <persistence-unit name="BibliotecaPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>christopherfa.model.ElementoCatalogo</class>
        <class>christopherfa.model.Libro</class>
        <class>christopherfa.model.Rivista</class>
        <class>christopherfa.model.Utente</class>
        <class>christopherfa.model.Prestito</class>

        <properties>
            <property name="javax.persistence.jdbc.driver" value="org.postgresql.Driver" />
            <property name="javax.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/U4W3D5" />
            <property name="javax.persistence.jdbc.user" value="postgres" />
            <property name="javax.persistence.jdbc.password" value="1234" />

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect" />
            <property name="hibernate.hbm2ddl.auto" value="update" /> <property name="hibernate.show_sql" value="true" />
        </properties>
    </persistence-unit>
</persistence>